exportgraphics(fig, '../figureB6_ConsLeisComplementarity.pdf', 'ContentType', 'vector'); 
clear fig;

%% ==========================================================================
%   indirect inference based on irfs 
%  ==========================================================================

x_=xp(:,1); dynare dmp_baseline_nom_rigid_matching.mod;

return

%% ==========================================================================
%   checking robustness of IRFs with respect to different calibrations
%  ==========================================================================
iter = 15;%510; 
rand_numb = NaN(28,iter); 
difference = NaN(20,10, iter, 4); 
rx=rand(iter,28); 
x_= NaN;

for i=1:iter

    x_(5,1)  = 0.98 + (0.9999-0.98).*rx(i,5);   % beta
    x_(6,1)  = 0;                               % alpha
    x_(7,1)  = 0.5 + (0.7-0.5).*rx(i,7);        % gshare
    x_(8,1)  = 1;                               % 5 + (15-5).*rx(i,8); % tfp
    x_(9,1)  = 0.9 + (0.98-0.9).*rx(i,9);       % rhog
    x_(10,1) = 0.10 + (0.341-0.10).*rx(i,10);   % sigma
    x_(11,1) = 0.35 + (0.55-0.35).*rx(i,11);    % gamma
    x_(12,1) = 0.2 + (0.4-0.2).*rx(i,12);       % p
    x_(13,1) = 0.65 + (0.75-0.65).*rx(i,13);    % theta
    x_(14,1) = 0.8 + (0.98-0.8).*rx(i,14);      % zeta
    x_(15,:) = 0.0 + (0.0-0.0).*rx(i,15);       % rhorw
    x_(16,:) = 0.01 + (0.05-0.01).*rx(i,16);    % rhobar
    x_(17,:) = (-0.1) + (0.1-(-0.1)).*rx(i,17); % mua
    x_(18,:) = 0.08 + (0.16-0.08).*rx(i,18);    % siga
    x_(19,:) = 0.03 + (0.07-0.03).*rx(i,19);    % rhotilde
    x_(20,:) = 0.65 + (.75-0.65).*rx(i,20);     % thetaP 
    x_(21,:) = 1.1 + (2.0-1.1).*rx(i,21);       % phi_pi
    x_(22,:) = 0.00 + (0.2-0.00).*rx(i,22);     % phi_y
    x_(23,:) = 0.00 + (0.6-0.00).*rx(i,23);     % rho_i
    x_(24,:) = 0.00 + (0.0-0.00).*rx(i,24);     % xi (non-Ric)
    x_(25,:) = 0.00;                            % habit form
    x_(26,:) = 0.00 + (0.4-0.00).*rx(i,26);     % gammaP (infl. index.)
    x_(27,:) = 0.00;                            % + (1-0.00).*rx(i,27); % FC in BC
    x_(28,:) = 0.00 + (0.0-0.00).*rx(i,28);     % alphaG (G in PF)

% for basline
    x_(1:4,1) = xp(1:4,1);
    try
        dynare dmp_baseline_nom_rigid.mod
        eig = sum(abs(oo_.dr.eigval)>1);
        if eig ==9
            %irf_sc0 = cat(2, ylog_vg, nlog_vg, u_vg, wlog_vg, clog_vg, glog_vg, thetalog_vg, S_vg, ulog_vg, pi_vg);
            irf_sc0 = cat(2, oo_.irfs.ylog_vg', oo_.irfs.nlog_vg', oo_.irfs.u_vg',oo_.irfs.wlog_vg', oo_.irfs.clog_vg',oo_.irfs.glog_vg',oo_.irfs.thetalog_vg', oo_.irfs.S_vg', oo_.irfs.ulog_vg', oo_.irfs.pi_vg');            
        else
            irf_sc0 = 'NaN';
        end
    catch
        irf_sc0 = 'NaN';
    end

% for eta
    x_(1:4,1) = xp(1:4,1); x_(1) = xp(1,2);
    try
        dynare dmp_baseline_nom_rigid.mod
        eig = sum(abs(oo_.dr.eigval)>1);
        if eig ==9
            %irf_sc1 = cat(2, ylog_vg, nlog_vg, u_vg, wlog_vg, clog_vg, glog_vg, thetalog_vg, S_vg, ulog_vg, pi_vg);
            irf_sc1 = cat(2, oo_.irfs.ylog_vg', oo_.irfs.nlog_vg', oo_.irfs.u_vg',oo_.irfs.wlog_vg'*1, oo_.irfs.clog_vg', oo_.irfs.glog_vg',oo_.irfs.thetalog_vg'*.7, oo_.irfs.S_vg', oo_.irfs.ulog_vg', oo_.irfs.pi_vg');
        else
            irf_sc1 = 'NaN';
        end
    catch
        irf_sc1 = 'NaN';
    end

    if all([isnumeric(irf_sc0),isnumeric(irf_sc1)]) == 1
        difference(:,:,i,1) = irf_sc0-irf_sc1;
    else
    end
    clear irf_sc1

% for varphi
    x_(1:4,1) = xp(1:4,1); x_(2) = 0.5;
    try
        dynare dmp_baseline_nom_rigid.mod
        eig = sum(abs(oo_.dr.eigval)>1);
        if eig ==9
            %irf_sc1 = cat(2, ylog_vg, nlog_vg, u_vg, wlog_vg, clog_vg, glog_vg, thetalog_vg, S_vg, ulog_vg, pi_vg);
            irf_sc1 = cat(2, oo_.irfs.ylog_vg', oo_.irfs.nlog_vg', oo_.irfs.u_vg',oo_.irfs.ulog_vg'*1, oo_.irfs.clog_vg', oo_.irfs.glog_vg',oo_.irfs.thetalog_vg', oo_.irfs.S_vg', oo_.irfs.ulog_vg', oo_.irfs.pi_vg');
        else
            irf_sc1 = 'NaN';
        end
    catch
        irf_sc1 = 'NaN';
    end

    if all([isnumeric(irf_sc0),isnumeric(irf_sc1)]) == 1
        difference(:,:,i,2) = irf_sc0-irf_sc1;
    else
    end
    clear irf_sc1

% for varsigma
    x_(1:4,1) = xp(1:4,1); x_(3) = xp(3,2);
    try
        dynare dmp_baseline_nom_rigid.mod
        eig = sum(abs(oo_.dr.eigval)>1);
        if eig ==9
            %irf_sc1 = cat(2, ylog_vg, nlog_vg, u_vg, wlog_vg, clog_vg, glog_vg, thetalog_vg, S_vg, ulog_vg, pi_vg);
            irf_sc1 = cat(2, oo_.irfs.ylog_vg', oo_.irfs.nlog_vg', oo_.irfs.u_vg', oo_.irfs.wlog_vg', oo_.irfs.clog_vg', oo_.irfs.glog_vg',oo_.irfs.thetalog_vg'*2, oo_.irfs.S_vg', oo_.irfs.ulog_vg', oo_.irfs.pi_vg');
        else
            irf_sc1 = 'NaN';
        end
    catch
        irf_sc1 = 'NaN';
    end

    if all([isnumeric(irf_sc0),isnumeric(irf_sc1)]) == 1
        difference(:,:,i,3) = irf_sc0-irf_sc1;
    else
    end
    clear irf_sc1

% for tau
    x_(1:4,1) = xp(1:4,1); x_(4) = xp(4,2);
    try
        %dynare dmp_baseline_all_frictions.mod
        eig = sum(abs(oo_.dr.eigval)>1);
        if eig ==9
            %irf_sc1 = cat(2, ylog_vg, nlog_vg, u_vg, wlog_vg, clog_vg, glog_vg, thetalog_vg, S_vg, ulog_vg, pi_vg);
            irf_sc1 = cat(2, oo_.irfs.ylog_vg', oo_.irfs.nlog_vg', oo_.irfs.u_vg', oo_.irfs.wlog_vg', oo_.irfs.clog_vg', oo_.irfs.glog_vg',-oo_.irfs.thetalog_vg', oo_.irfs.S_vg', oo_.irfs.ulog_vg', oo_.irfs.pi_vg');
        else
            irf_sc1 = 'NaN';
        end
    catch
        irf_sc1 = 'NaN';
    end

    if all([isnumeric(irf_sc0),isnumeric(irf_sc1)]) == 1
        difference(:,:,i,4) = irf_sc0-irf_sc1; % irf(tau='klein') - irf(tau='groß) > 0
    else
    end
    clear irf_sc1; clc

    rand_numb(:,i) = x_;
end

v_sel = [1,2,7,4,10]; % [1,2,9,4,7,10];
x_differ=difference;

ho=2;

% boxplots
figure('Name','boxplots to check the IRFs #1','Position', [fx fy fwidth fheight-360]);
subplot(1,3,1);
boxplot(squeeze(mean(x_differ(1:ho,v_sel,:,1),1))','labels',{names(v_sel,:)}, 'Jitter', 10000);
bp = gca;
bp.XAxis.TickLabelInterpreter = 'latex'; set(gca,'fontsize',10); xtickangle(45);
title({'UD $(\eta)$: irf$(\eta^{\textrm{Low}})-$irf$(\eta^{\textrm{High}})$'}, ...
    'Interpreter','latex','FontSize',10);
ylim([-0.2 0.2]); grid on;

subplot(1,3,2);
boxplot(squeeze(mean(x_differ(1:ho,v_sel,:,2),1))','labels',{names(v_sel,:)}, 'Jitter', 10000);
bp = gca;
bp.XAxis.TickLabelInterpreter = 'latex'; set(gca,'fontsize',10); xtickangle(45);
title('BRR $(\varphi)$: irf$(\varphi^{\textrm{Low}})-$irf$(\varphi^{\textrm{High}})$', ...
    'Interpreter','latex','FontSize',10);
ylim([-0.2 0.2]); grid on;

subplot(1,3,3);
boxplot(squeeze(mean(x_differ(1:ho,v_sel,:,3),1))','labels',{names(v_sel,:)}, 'Jitter', 10000);
bp = gca;
bp.XAxis.TickLabelInterpreter = 'latex'; set(gca,'fontsize',10); xtickangle(45);
title({'EPL $(\varsigma)$:  irf$(\varsigma^{\textrm{Low}}-$irf$(\varsigma^{\textrm{High}})$'}, ...
    'Interpreter','latex','FontSize',10);
ylim([-0.3 0.1]); grid on;

